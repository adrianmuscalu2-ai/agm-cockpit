{
  "name": "agm",
  "version": "0.1.0",
  "private": true,
  "description": "AGM AI-assisted vehicle transport management system",
  "scripts": {
    "build": "pnpm --filter @agm/api build",
    "dev": "pnpm --filter @agm/api start:dev",
    "start": "pnpm --filter @agm/api start",
    "lint": "pnpm --filter @agm/api lint",
    "test": "pnpm --filter @agm/api test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed/seed.ts"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3"
}
