generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                  String           @id @default(uuid()) @db.Uuid
  companyName         String
  countryCode         String           @db.VarChar(2)
  defaultCurrencyCode String           @db.VarChar(3)
  timezone            String           @default("Europe/Berlin")
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  users               User[]
  roles               Role[]
  lifecycleStates     LifecycleState[]
  transports          TransportJob[]
}

model User {
  id                   String     @id @default(uuid()) @db.Uuid
  companyId            String     @db.Uuid
  company              Company    @relation(fields: [companyId], references: [id])
  displayName          String
  email                String
  passwordHash         String
  phoneNumber          String?
  status               String     @default("Active")
  personalDataStatus   String     @default("Active")
  anonymizedAt         DateTime?
  retentionUntil       DateTime?
  legalRetentionReason String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  lastLoginAt          DateTime?
  roles                UserRole[]

  @@unique([companyId, email])
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  company     Company    @relation(fields: [companyId], references: [id])
  code        String
  displayName String
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  users       UserRole[]

  @@unique([companyId, code])
}

model UserRole {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @db.Uuid
  userId           String   @db.Uuid
  roleId           String   @db.Uuid
  assignedByUserId String?  @db.Uuid
  assignedAt       DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  role             Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model TurnAdminCredential {
  id             String    @id
  passwordHash   String
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model LifecycleState {
  id            String                     @id @default(uuid()) @db.Uuid
  companyId     String?                    @db.Uuid
  company       Company?                   @relation(fields: [companyId], references: [id])
  countryCode   String?                    @db.VarChar(2)
  code          String
  displayName   String
  description   String?
  sortOrder     Int                        @default(0)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  deprecatedAt  DateTime?
  transports    TransportJob[]
  fromHistories TransportJobStateHistory[] @relation("FromLifecycleState")
  toHistories   TransportJobStateHistory[] @relation("ToLifecycleState")

  @@unique([companyId, code])
  @@index([code])
}

model TransportJob {
  id                      String                     @id @default(uuid()) @db.Uuid
  companyId               String                     @db.Uuid
  company                 Company                    @relation(fields: [companyId], references: [id])
  transportNumber         String
  currentLifecycleStateId String                     @db.Uuid
  currentLifecycleState   LifecycleState             @relation(fields: [currentLifecycleStateId], references: [id])
  pickupAddressSnapshot   Json?
  deliveryAddressSnapshot Json?
  sourceConfidenceScore   Decimal?                   @db.Decimal(5, 2)
  plannedPickupFrom       DateTime?
  plannedPickupTo         DateTime?
  plannedDeliveryAt       DateTime?
  paymentAmount           Decimal?                   @db.Decimal(12, 2)
  currencyCode            String                     @default("EUR") @db.VarChar(3)
  isBlocked               Boolean                    @default(false)
  isArchived              Boolean                    @default(false)
  validationReportId      String?                    @db.Uuid
  auditEventId            String?                    @db.Uuid
  createdByUserId         String                     @db.Uuid
  updatedByUserId         String?                    @db.Uuid
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  stateHistory            TransportJobStateHistory[]
  validationReports       BusinessValidationReport[]
  auditEvents             AuditEvent[]
  financialLedger         FinancialLedger[]

  @@unique([companyId, transportNumber])
  @@index([companyId, currentLifecycleStateId])
  @@index([createdAt])
}

model TransportJobStateHistory {
  id                        String          @id @default(uuid()) @db.Uuid
  companyId                 String          @db.Uuid
  transportJobId            String          @db.Uuid
  transportJob              TransportJob    @relation(fields: [transportJobId], references: [id])
  fromLifecycleStateId      String?         @db.Uuid
  fromLifecycleState        LifecycleState? @relation("FromLifecycleState", fields: [fromLifecycleStateId], references: [id])
  toLifecycleStateId        String          @db.Uuid
  toLifecycleState          LifecycleState  @relation("ToLifecycleState", fields: [toLifecycleStateId], references: [id])
  businessAction            String
  transitionReason          String?
  transitionedByUserId      String          @db.Uuid
  transitionedAt            DateTime        @default(now())
  approvedByUserId          String?         @db.Uuid
  validationReportId        String?         @db.Uuid
  relatedAIRecommendationId String?         @db.Uuid
  relatedAuditEventId       String          @db.Uuid
  metadata                  Json?

  @@index([transportJobId, transitionedAt])
  @@index([validationReportId])
}

model BusinessValidationReport {
  id                       String        @id @default(uuid()) @db.Uuid
  validationReportId       String        @unique @db.Uuid
  companyId                String        @db.Uuid
  validationType           String
  validationVersion        String
  parentValidationReportId String?       @db.Uuid
  correlationId            String        @db.Uuid
  requestId                String        @db.Uuid
  overallResult            String
  executedChecks           Json
  relatedBusinessAction    String
  relatedEntityType        String
  relatedEntityId          String        @db.Uuid
  transportJobId           String?       @db.Uuid
  transportJob             TransportJob? @relation(fields: [transportJobId], references: [id])
  auditEventId             String?       @db.Uuid
  stateHistoryId           String?       @db.Uuid
  executionDurationMs      Int
  createdAt                DateTime      @default(now())
  createdByUserId          String        @db.Uuid

  @@index([companyId, validationType])
  @@index([correlationId])
  @@index([transportJobId])
}

model AuditEvent {
  id                 String        @id @default(uuid()) @db.Uuid
  companyId          String        @db.Uuid
  actorUserId        String?       @db.Uuid
  actorType          String
  actionCode         String
  entityType         String
  entityId           String        @db.Uuid
  transportJobId     String?       @db.Uuid
  transportJob       TransportJob? @relation(fields: [transportJobId], references: [id])
  occurredAt         DateTime      @default(now())
  reason             String?
  beforeSnapshot     Json?
  afterSnapshot      Json?
  evidenceMetadataId String?       @db.Uuid
  aiRecommendationId String?       @db.Uuid
  humanDecisionId    String?       @db.Uuid
  validationReportId String?       @db.Uuid
  offlineSyncEventId String?       @db.Uuid
  ipAddress          String?
  deviceId           String?       @db.Uuid
  requestId          String        @db.Uuid
  correlationId      String        @db.Uuid
  metadata           Json?

  @@index([transportJobId, occurredAt])
  @@index([correlationId])
  @@index([validationReportId])
}

model EvidenceMetadata {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @db.Uuid
  transportJobId   String?  @db.Uuid
  evidenceType     String
  storageProvider  String
  storageKey       String
  originalFileName String?
  mimeType         String?
  sizeBytes        Int?
  checksumSha256   String?
  description      String?
  uploadedByUserId String   @db.Uuid
  createdAt        DateTime @default(now())
  metadata         Json?

  @@unique([companyId, storageProvider, storageKey])
  @@index([companyId, transportJobId])
  @@index([companyId, evidenceType])
}

model IncidentReport {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @db.Uuid
  transportJobId   String    @db.Uuid
  incidentType     String
  severity         String
  status           String    @default("open")
  title            String
  description      String?
  reportedByUserId String    @db.Uuid
  resolvedByUserId String?   @db.Uuid
  resolvedAt       DateTime?
  resolutionNotes  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  metadata         Json?

  @@index([companyId, status])
  @@index([transportJobId, createdAt])
  @@index([companyId, severity])
}

model FinancialLedger {
  id                    String       @id @default(uuid()) @db.Uuid
  companyId             String       @db.Uuid
  transportJobId        String       @db.Uuid
  transportJob          TransportJob @relation(fields: [transportJobId], references: [id])
  ledgerNumber          String
  entryType             String
  amount                Decimal      @db.Decimal(12, 2)
  currencyCode          String       @db.VarChar(3)
  exchangeRateToBase    Decimal?     @db.Decimal(12, 6)
  occurredAt            DateTime
  recordedAt            DateTime     @default(now())
  recordedByUserId      String       @db.Uuid
  evidenceMetadataId    String?      @db.Uuid
  reversesLedgerEntryId String?      @db.Uuid
  description           String?
  metadata              Json?
  validationReportId    String?      @db.Uuid
  auditEventId          String       @db.Uuid

  @@index([transportJobId, occurredAt])
  @@index([companyId, ledgerNumber])
  @@index([validationReportId])
}
